# Copy to .env and fill in real values. Never commit the real .env file.

NODE_ENV=development
PORT=3001

# Postgres (Supabase) connection string
DATABASE_URL=

# Auth token signing secrets — REQUIRED in production, app refuses to boot without them
JWT_SECRET=
JWT_REFRESH_SECRET=

# Comma-separated list of extra allowed CORS origins in production (e.g. your deployed frontend domain)
ALLOWED_ORIGINS=

# Public URL of this deployment, used for OpenRouter attribution headers
APP_URL=http://localhost:3000

# LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
DEEPSEEK_MODEL=

# OCR
OCR_API_KEY=
OCR_SPACE_API_KEY=
USE_MOCK_OCR=false

# Upstash Redis (locks / caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WhatsApp Business API (prospect invites)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_INVITE_TEMPLATE_NAME=
WHATSAPP_SUPPORT_NUMBER=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Set to true to disable the global API rate limiter (dev/test only)
DISABLE_RATE_LIMIT=false
